---
import { MapPin, ChevronDown } from "lucide-astro";
---

<section class="locations-wrapper" aria-labelledby="locations-title">
  <div class="locations-container">
    <div class="section-header">
      <h2 id="locations-title" class="section-title">Nuestras Ubicaciones</h2>
    </div>

    <div class="location-cards">
      <article class="location-card">
        <div class="location-media-wrapper">
          <img
            src="/images/clinic_valdivia.png"
            alt="Clínica Dermaval Sede Valdivia"
            class="location-image"
          />
        </div>

        <div class="location-content">
          <h3 class="location-name">
            <MapPin size={20} color="var(--color-primary-blue)" /> Dermaval
          </h3>
          <p class="location-address">Av. Ramón Picarte 427, Valdivia</p>
          <a href="https://agendapro.com/site/cl/dermaval/388430" target="_blank" class="location-agenda-btn">Agendar en Valdivia</a>
        </div>

        <details class="map-details">
          <summary class="map-summary">
            Ver ubicación en el mapa
            <ChevronDown class="map-chevron" size={20} />
          </summary>
          <div class="location-map-wrapper">
            <iframe
              src="https://maps.google.com/maps?q=Av.%20Ram%C3%B3n%20Picarte%20427,%20Valdivia&t=&z=15&ie=UTF8&iwloc=&output=embed"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            >
            </iframe>
          </div>
        </details>
      </article>

      <article class="location-card">
        <div class="location-media-wrapper">
          <img
            src="/images/clinic_temuco.png"
            alt="Clínica Beeld Sede Temuco"
            class="location-image"
          />
        </div>

        <div class="location-content">
          <h3 class="location-name">
            <MapPin size={20} color="var(--color-primary-blue)" /> Clínica Beeld
          </h3>
          <p class="location-address">Torremolinos 410, local 223A, Temuco</p>
          <a href="https://clinicabeeld.site.agendapro.com/cl/sucursal/138662/profesional/306232" target="_blank" class="location-agenda-btn">Agendar en Temuco</a>
        </div>

        <details class="map-details">
          <summary class="map-summary">
            Ver ubicación en el mapa
            <ChevronDown class="map-chevron" size={20} />
          </summary>
          <div class="location-map-wrapper">
            <iframe
              src="https://maps.google.com/maps?q=Torremolinos%20410,%20Temuco&t=&z=15&ie=UTF8&iwloc=&output=embed"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            >
            </iframe>
          </div>
        </details>
      </article>
    </div>
  </div>
</section>

<style>
  .locations-wrapper {
    padding: 60px 20px;
    background-color: var(--color-light-gray);
    margin-bottom: 40px;
  }

  .locations-container {
    max-width: 80%;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-title {
    font-size: 2rem;
    margin-top: 8px;
    color: var(--color-primary-blue);
  }

  @media (min-width: 769px) {
    .section-title {
      font-size: 2.5rem;
    }
  }

  .location-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: start;
  }

  .location-card {
    background-color: var(--color-white);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    border: 1px solid #e0e0e0;
  }

  .location-media-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #eee;
  }

  .location-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .location-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
    flex-grow: 1;
  }

  .location-name {
    font-size: 1.25rem;
    color: var(--color-black);
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0;
  }

  .location-address {
    color: var(--color-dark-gray);
    line-height: 1.5;
    margin-bottom: 24px;
  }

  .location-agenda-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
    height: 48px;
    box-sizing: border-box;
    white-space: nowrap;
    background-color: var(--color-primary-blue);
    color: var(--color-white);
    text-decoration: none;
    border-radius: 9999px;
    font-family: var(--font-heading);
    font-weight: 600;
    transition: background-color 0.2s, filter 0.2s;
  }

  .location-agenda-btn:active {
    filter: brightness(0.9);
  }

  @media (hover: hover) {
    .location-agenda-btn:hover {
      filter: brightness(0.9);
    }
  }

  .location-map-wrapper {
    width: 100%;
    height: 250px;
    border-top: 1px solid #eee;
    opacity: 0;
    transform: translateY(-10px);
    animation: mapSlideDown 0.3s ease forwards;
  }

  @keyframes mapSlideDown {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .location-map-wrapper iframe {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Estilos para el desplegable del mapa */
  .map-details {
    width: 100%;
    border-top: 1px solid #eee;
  }

  .map-summary {
    padding: 16px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    color: var(--color-primary-blue);
    cursor: pointer;
    list-style: none;
    transition: background-color 0.2s;
  }

  .map-summary::-webkit-details-marker {
    display: none;
  }

  .map-chevron {
    transition: transform 0.3s ease;
  }

  .map-details[open] .map-chevron {
    transform: rotate(180deg);
  }

  .map-summary:hover {
    background-color: var(--color-light-gray);
  }

  .map-details[open] .map-summary {
    border-bottom: 1px solid #eee;
  }

  @media (min-width: 769px) {
    .location-cards {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }

    .locations-wrapper {
      padding: 80px 40px;
    }
  }
</style>
