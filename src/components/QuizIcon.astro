{name === 'si_habito' && (
  <svg {...svgProps}>
    <!-- Moño tirante -->
    <circle cx="12" cy="10" r="6" />
    <path d="M12 4v-2" />
    <ellipse cx="12" cy="2" rx="3" ry="1.5" />
  </svg>
)}

{name === 'no_habito' && (
  <svg {...svgProps}>
    <!-- Cabello suelto -->
    <path d="M8 4c-3 3-4 8-4 14" />
    <path d="M16 4c3 3 4 8 4 14" />
    <path d="M6 10c0 4 2 8 6 8s6-4 6-8" />
  </svg>
)}

{name === 'sano' && (
  <svg {...svgProps}>
    <!-- Sano -->
    <path d="M4 20h16" />
    <path d="M12 20V4" stroke-width="3" />
    <path d="M8 10l3 3 5-5" stroke="#25D366" />
  </svg>
)}

{name === 'descamacion' && (
  <svg {...svgProps}>
    <!-- Descamación -->
    <path d="M4 20h16" />
    <path d="M12 20V4" stroke-width="2" />
    <path d="M7 16l2 2M7 18l2-2" />
    <path d="M15 12l2 2M15 14l2-2" />
    <path d="M8 8l2 2M8 10l2-2" />
