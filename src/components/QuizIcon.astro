)}

{name === 'enrojecimiento' && (
  <svg {...svgProps}>
    <!-- Enrojecimiento -->
    <path d="M4 20h16" />
    <path d="M12 20V4" stroke-width="2" />
    <path d="M8 20c0-2 1-4 2-5s2-2 4 0 2 3 2 5" stroke="#E53E3E" stroke-dasharray="2 2" />
  </svg>
