{name === 'gruesa' && (
  <svg {...svgProps}>
    <!-- Hebra gruesa -->
    <path d="M12 2v20" stroke-width="6" />
  </svg>
)}

{name === 'fina_hebra' && (
  <svg {...svgProps}>
    <!-- Hebra fina -->
    <path d="M12 2v20" stroke-width="1" />
