{name === 'quebradiza' && (
  <svg {...svgProps}>
    <!-- Hebra quebradiza -->
    <path d="M12 22V10" stroke-width="2" />
    <path d="M12 10l-4-8" stroke-width="2" />
    <path d="M12 10l4-8" stroke-width="2" />
