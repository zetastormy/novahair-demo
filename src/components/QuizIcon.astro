{name === 'hormonas' && (
  <svg {...svgProps}>
    <!-- Píldora -->
    <path d="M10.5 20.5l-6-6a4.24 4.24 0 0 1 0-6l6-6a4.24 4.24 0 0 1 6 0l6 6a4.24 4.24 0 0 1 0 6l-6 6a4.24 4.24 0 0 1-6 0z" />
    <path d="M8 8l8 8" />
