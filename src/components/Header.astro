---
import { ChevronDown, ClipboardCheck } from 'lucide-astro';
---

<header class="header-wrapper">
  <div class="header">
    <div class="logo">
      <span class="logo-title">Nova<br/>Hair</span>
      <span class="logo-subtitle">medicina estética capilar</span>
    </div>

    <nav class="desktop-nav">
      <a href="#">Inicio</a>
      <a href="#">Tratamientos</a>
      <a href="#">Blog</a>
    </nav>

    <div class="header-actions">
      <button class="agendar-btn" aria-label="Abrir menú de agendamiento">
        Agendar
        <ChevronDown size={16} strokeWidth={1.5} />
      </button>
      <a href="#" class="test-btn">
        <ClipboardCheck size={16} strokeWidth={2} />
        Test Capilar
      </a>
    </div>
  </div>
</header>

<style>
  .header-wrapper {
    background-color: var(--color-white);
    border-bottom: 1px solid var(--color-light-gray);
    width: 100%;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .logo {
    display: flex;
    flex-direction: column;
    border: 1px dashed #999;
    padding: 8px 12px;
    border-radius: 8px;
  }

  .logo-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.125rem;
    line-height: 1.1;
    color: var(--color-black);
  }

  .logo-subtitle {
    font-family: var(--font-body);
    font-size: 0.625rem;
    color: var(--color-dark-gray);
    margin-top: 4px;
  }

  .desktop-nav {
    display: none;
    gap: 32px;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .desktop-nav a {
    color: var(--color-black);
    transition: color 0.2s;
  }

  .desktop-nav a:hover {
    color: var(--color-pink-primary);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .agendar-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    min-height: 48px;
    border: 1px dashed #999;
    border-radius: 24px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-black);
    background-color: transparent;
    transition: background-color 0.2s;
  }

  .agendar-btn:hover, .agendar-btn:active {
    background-color: var(--color-light-gray);
  }

  .test-btn {
    display: none;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background-color: var(--color-dark-gray);
    color: var(--color-white);
    border-radius: 8px;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.875rem;
    min-height: 48px;
    transition: background-color 0.2s;
  }

  .test-btn:hover {
    background-color: var(--color-black);
  }

  @media (min-width: 769px) {
    .desktop-nav {
      display: flex;
    }
    .test-btn {
      display: flex;
    }
  }
</style>
