---
import { Calendar } from 'lucide-astro';
import { siWhatsapp } from 'simple-icons';
---

<section class="treatments-cta">
  <div class="cta-content">
    <h2>¿Necesitas agendar o más información?</h2>
    <p>Contacta con nuestro equipo para una evaluación personalizada.</p>
    
    <div class="cta-buttons">
      <a href="#" class="btn-whatsapp">
        <span class="icon-wrapper" set:html={siWhatsapp.svg} aria-hidden="true" />
        WhatsApp
      </a>
      <a href="https://agendapro.com/site/cl/dermaval/388430" target="_blank" class="btn-dark">
        <Calendar size={20} strokeWidth={2} aria-hidden="true" />
        Agendar Valdivia
      </a>
      <a href="https://clinicabeeld.site.agendapro.com/cl/sucursal/138662/profesional/306232" target="_blank" class="btn-dark">
        <Calendar size={20} strokeWidth={2} aria-hidden="true" />
        Agendar Temuco
      </a>
    </div>
  </div>
</section>

<style>
  .treatments-cta {
    margin-top: 4rem;
    padding: 2.5rem 1.5rem;
    background-color: var(--color-white);
    border: 1px solid #E0E0E0;
    border-radius: 12px;
    text-align: center;
  }

  .cta-content h2 {
    font-size: 1.25rem;
    color: var(--color-dark-gray);
    margin-bottom: 0.5rem;
  }

  .cta-content p {
    font-size: 0.95rem;
    color: #666666;
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .btn-whatsapp, .btn-dark {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    max-width: 300px;
    height: 48px;
    box-sizing: border-box;
    white-space: nowrap;
    padding: 0 1.5rem;
    border-radius: 9999px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .btn-whatsapp:active, .btn-dark:active {
    transform: scale(0.98);
  }

  @media (hover: hover) {
    .btn-whatsapp:hover, .btn-dark:hover {
      filter: brightness(0.9);
    }
  }

  .btn-whatsapp {
    background-color: #25D366;
    color: var(--color-white);
  }

  .btn-dark {
    background-color: var(--color-dark-gray);
    color: var(--color-white);
  }

  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  @media (min-width: 768px) {
    .treatments-cta {
      padding: 3rem 2rem;
    }
    .cta-content h2 {
      font-size: 1.5rem;
    }
    .cta-buttons {
      flex-direction: row;
      justify-content: center;
    }
    .btn-whatsapp, .btn-dark {
      width: auto;
    }
  }
</style>
