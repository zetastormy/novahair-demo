---
import { Instagram, Facebook, Phone } from 'lucide-astro';
---

<footer class="footer-wrapper">
  <div class="footer-container">
    <p class="copyright">© 2026 NovaHair - Clínica Capilar</p>
    <div class="footer-right">
      <div class="contact-info">
        <a href="tel:+56987545928" aria-label="Llamar a la clínica">
          <Phone size={16} />
          +56 9 8754 5928
        </a>
      </div>
      <div class="social-links">
        <a href="https://www.instagram.com/novahair_cl/" target="_blank" aria-label="Instagram"><Instagram size={20} /></a>
        <a href="https://www.facebook.com/580451815156731" target="_blank" aria-label="Facebook"><Facebook size={20} /></a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-wrapper {
    background-color: var(--color-white);
    border-top: 1px solid var(--color-light-gray);
    padding: 24px 20px 100px 20px;
    width: 100%;
  }

  .footer-container {
    max-width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .copyright {
    font-size: 0.75rem;
    color: var(--color-dark-gray);
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .social-links {
    display: flex;
    gap: 16px;
  }

  .social-links a {
    color: var(--color-dark-gray);
    transition: color 0.2s;
  }

  .contact-info {
    font-size: 0.875rem;
    color: var(--color-dark-gray);
  }

  .contact-info a {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-dark-gray);
    transition: color 0.2s;
  }

  @media (hover: hover) {
    .social-links a:hover,
    .contact-info a:hover {
      color: var(--color-primary-blue);
    }
  }

  @media (min-width: 769px) {
    .footer-wrapper {
      padding: 24px 20px;
    }
    .footer-container {
      flex-direction: row;
      justify-content: space-between;
    }
    .footer-right {
      flex-direction: row;
      gap: 32px;
    }
  }
</style>
