---
import { Stethoscope, HeartPulse, Smile } from 'lucide-astro';
---

<section class="trajectory-wrapper" aria-labelledby="trajectory-title">
  <div class="trajectory-container">
    <div class="section-header">
      <h2 id="trajectory-title" class="section-title">Nuestra Trayectoria</h2>
    </div>
    
    <div class="timeline">
      <article class="timeline-item">
        <div class="timeline-icon" style="border-color: var(--color-primary-blue); background-color: rgba(92, 107, 192, 0.1);">
          <Stethoscope size={24} color="var(--color-primary-blue)" />
        </div>
        <div class="timeline-content">
          <p class="timeline-text">Contamos con <strong>personal especializado</strong> en <strong>tratamientos estéticos capilares</strong>.</p>
        </div>
      </article>
      
      <article class="timeline-item">
        <div class="timeline-icon" style="border-color: var(--color-accent-green); background-color: rgba(37, 211, 102, 0.1);">
          <HeartPulse size={24} color="var(--color-accent-green)" />
        </div>
        <div class="timeline-content">
          <p class="timeline-text">Nos encontramos <strong>mejorando tu calidad de vida</strong> desde <strong>2023</strong>.</p>
        </div>
      </article>

      <article class="timeline-item">
        <div class="timeline-icon" style="border-color: var(--color-gold); background-color: rgba(255, 193, 7, 0.1);">
          <Smile size={24} color="var(--color-gold)" />
        </div>
        <div class="timeline-content">
          <p class="timeline-text"><strong>Más de 150 pacientes satisfechos</strong></p>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .trajectory-wrapper {
    padding: 60px 20px;
    background-color: var(--color-light-gray);
  }

  .trajectory-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-title {
    font-size: 2rem;
    margin-top: 8px;
    color: var(--color-primary-blue);
  }

  @media (min-width: 769px) {
    .section-title {
      font-size: 2.5rem;
    }
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .timeline-item {
    display: flex;
    align-items: center;
    gap: 16px;
    background-color: var(--color-white);
    padding: 24px;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  }

  .timeline-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 2px solid #ccc;
    flex-shrink: 0;
  }

  .timeline-year {
    font-size: 1.25rem;
    color: var(--color-black);
    margin-bottom: 8px;
  }

  .timeline-text {
    font-size: 0.875rem;
    color: var(--color-dark-gray);
    line-height: 1.5;
  }

  .timeline-text strong {
    font-weight: 700;
    color: var(--color-black);
  }

  @media (min-width: 769px) {
    .timeline {
      flex-direction: row;
      align-items: stretch;
      gap: 24px;
    }
    .timeline-item {
      flex: 1;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
