---
import {
  ChevronDown,
  CheckCircle,
  Target,
  Activity,
  Users,
  Clock,
  Tag,
} from "lucide-astro";

interface Detail {
  icon: "CheckCircle" | "Target" | "Activity" | "Users" | "Clock";
  text: string;
}

interface Props {
  title: string;
  description: string;
  image: string;
  details: Detail[];
  duration: string;
  price: string;
  disclaimer?: string;
  id?: string;
}

const { title, description, image, details, duration, price, disclaimer, id } =
  Astro.props;

const iconMap = {
  CheckCircle,
  Target,
  Activity,
  Users,
  Clock,
};
---

<article id={id} class="treatment-card">
  <div class="image-container">
    <img src={image} alt={`Imagen representativa de ${title}`} loading="lazy" />
  </div>

  <div class="card-content">
    <h2 class="treatment-title">{title}</h2>
    <p class="treatment-description">{description}</p>

    <details class="treatment-details">
      <summary class="details-summary">
        <span class="summary-text">Ver más información</span>
        <ChevronDown class="icon-chevron" size={20} />
      </summary>
      <div class="details-content">
        <div class="details-inner">
          <ul>
            {
              details.map((item) => {
                const Icon = iconMap[item.icon];
                return (
                  <li>
                    <Icon size={18} class="detail-icon" />
                    <span>{item.text}</span>
                  </li>
                );
              })
            }
          </ul>

          <div class="treatment-meta">
            <div class="meta-item">
              <span class="meta-label">
                <Clock size={16} class="meta-icon" /> Duración aproximada:
              </span>
              <span class="meta-value">{duration}</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">
                <Tag size={16} class="meta-icon" /> Valor referencial:
              </span>
              <span class="meta-value">{price}</span>
            </div>
            {disclaimer && <p class="meta-disclaimer">*{disclaimer}</p>}

            <div class="promo-container">
              <p class="promo-text">
                ¡Pregunta por nuestros <strong>packs</strong> y más información!
              </p>
              <a
                href={`https://wa.me/56987545928?text=${encodeURIComponent(`Hola, me gustaría recibir más información y consultar por packs del tratamiento: ${title}.`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="whatsapp-cta"
              >
                Cotizar por WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </details>
  </div>
</article>

<style>
  .treatment-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-white);
    border: 1px solid var(--color-light-gray);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  @media (hover: hover) {
    .treatment-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1);
    }
  }

  .image-container {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background-color: var(--color-light-gray);
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 1rem;
  }

  .treatment-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-dark-gray);
    margin: 0;
  }

  .treatment-description {
    font-size: 0.95rem;
    color: #666666;
    line-height: 1.5;
    margin: 0;
  }

  /* Accordion Styles */
  .treatment-details {
    margin-top: auto;
    border-top: 1px solid var(--color-light-gray);
    padding-top: 1rem;
  }

  .details-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-primary-blue);
    cursor: pointer;
    list-style: none; /* Hide default arrow */
    height: 48px; /* Fitts' Law */
    box-sizing: border-box;
    padding: 0;
    transition: color 0.2s;
  }

  /* Remove default arrows in webkit */
  .details-summary::-webkit-details-marker {
    display: none;
  }

  @media (hover: hover) {
    .details-summary:hover {
      color: var(--color-primary-blue);
      filter: brightness(1.2);
    }
  }

  .icon-chevron {
    transition: transform 0.3s ease;
  }

  details[open] .icon-chevron {
    transform: rotate(180deg);
  }

  .details-content {
    /* Animating height from 0 to actual height */
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease-out;
  }

  details[open] .details-content {
    grid-template-rows: 1fr;
  }

  .details-inner {
    overflow: hidden;
  }

  .details-inner ul {
    padding: 0;
    margin: 1rem 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    list-style: none;
  }

  .details-inner li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    color: #444;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .detail-icon {
    flex-shrink: 0;
    color: var(--color-primary-blue);
    margin-top: 2px;
  }

  @media (min-width: 768px) {
    .image-container {
      aspect-ratio: 16/9;
    }
  }

  /* Meta & CTA Styles */
  .treatment-meta {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--color-light-gray);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .meta-item {
    display: flex;
    justify-content: space-between;
    font-size: 0.95rem;
    color: var(--color-dark-gray);
  }

  .meta-label {
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .meta-icon {
    color: var(--color-primary-blue);
  }

  .meta-disclaimer {
    font-size: 0.8rem;
    color: #666;
    margin: 0;
    font-style: italic;
  }

  .promo-container {
    margin-top: 1rem;
    background-color: #f0fdf4; /* Light green tint */
    border: 1px solid #bbf7d0;
    border-radius: 8px;
    padding: 1rem;
    text-align: center;
  }

  .promo-text {
    margin: 0 0 0.8rem 0;
    font-size: 0.9rem;
    color: #166534;
  }

  .whatsapp-cta {
    display: inline-block;
    width: 100%;
    padding: 0.75rem;
    background-color: var(--color-accent-green);
    color: white;
    text-decoration: none;
    font-weight: 600;
    border-radius: 9999px;
    transition:
      background-color 0.2s,
      transform 0.1s;
  }

  @media (hover: hover) {
    .whatsapp-cta:hover {
      background-color: #1ea952;
    }
    .whatsapp-cta:active {
      transform: scale(0.98);
    }
  }
</style>
