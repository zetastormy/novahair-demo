<section class="hero-wrapper">
  <div class="hero">
    <div class="hero-content">
      <span class="badge">ESPECIALISTAS</span>
      <h1 class="hero-title">
        <span
          style="font-size: 0.55em; display: block; font-weight: 500; margin-bottom: 0.5rem; line-height: 1.3;"
          >Tenemos años de experiencia tratando la caída del cabello.</span
        >
        <span style="font-weight: bold;">Da el primer paso hacia tu recuperación.</span>
      </h1>
      <p class="hero-subtitle">
        Estudiamos y entendemos cómo afecta el estrés, las hormonas o el
        post-parto a la salud capilar. Encuentra tu diagnóstico médico y un
        tratamiento personalizado en un ambiente seguro y privado.
      </p>

      <div class="hero-actions">
        <a href="/test" class="cta-primary">Evalúa tu salud capilar</a>
        <a href="/tratamientos" class="cta-secondary">Ver tratamientos</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-wrapper {
    width: 100%;
    /* Overlay oscuro sobre la imagen de fondo */
    background:
      linear-gradient(to bottom, rgba(10, 20, 50, 0.6), rgba(10, 20, 50, 0.9)),
      url("/images/hero_bg_new.png");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 60px 20px;
    display: flex;
    justify-content: center;
  }

  .hero {
    width: 100%;
    max-width: 80%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-content {
    width: 100%;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 20px;
  }

  .badge {
    background-color: var(--color-gold);
    color: var(--color-white);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.75rem;
    padding: 6px 12px;
    border-radius: 16px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .hero-title {
    font-size: 2.25rem;
    line-height: 1.1;
    color: var(--color-white);
    font-weight: 800;
  }

  .hero-subtitle {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-white);
    opacity: 0.95;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    margin-top: 12px;
  }

  .cta-primary {
    background-color: var(--color-primary-blue);
    color: var(--color-white);
    padding: 0 24px;
    height: 48px;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    border-radius: 9999px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    width: 100%;
    transition:
      background-color 0.2s,
      filter 0.2s;
  }

  .cta-primary:active {
    background-color: var(--color-primary-blue);
    filter: brightness(0.9);
  }

  @media (hover: hover) {
    .cta-primary:hover {
      background-color: var(--color-primary-blue);
      filter: brightness(0.9);
    }
  }

  .cta-secondary {
    background-color: transparent;
    color: var(--color-white);
    padding: 0 24px;
    height: 48px;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    border: 2px solid var(--color-primary-blue);
    border-radius: 9999px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    width: 100%;
    transition:
      background-color 0.2s,
      color 0.2s;
    text-decoration: none;
  }

  .cta-secondary:active {
    background-color: var(--color-primary-blue);
    color: var(--color-white);
  }

  @media (hover: hover) {
    .cta-secondary:hover {
      background-color: var(--color-primary-blue);
      color: var(--color-white);
    }
  }

  @media (min-width: 769px) {
    .hero-wrapper {
      padding: 60px 40px; /* Tamaño vertical reducido */
    }
    .hero-title {
      font-size: 3rem;
    }
    .hero-subtitle {
      font-size: 1.125rem;
    }
    .hero-actions {
      width: fit-content;
      flex-direction: row;
    }
    .cta-primary,
    .cta-secondary {
      width: auto;
      min-width: 240px;
    }
  }
</style>
