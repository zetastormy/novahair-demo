---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { ChevronLeft, Calendar, Share2, Facebook, Twitter, Linkedin } from 'lucide-astro';
import { siWhatsapp } from 'simple-icons';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const formattedDate = new Intl.DateTimeFormat('es-CL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
}).format(entry.data.pubDate);
---

<Layout title={`${entry.data.title} | NovaHair Blog`} description={entry.data.description}>
  <div class="blog-header-spacing"></div>
  <article class="post-container">
    
    <div class="back-link-container">
      <a href="/blog" class="back-link">
        <ChevronLeft size={20} /> Volver al blog
      </a>
    </div>

    <!-- Hero Image -->
    <div class="post-hero">
      <img src={entry.data.heroImage || '/images/hero_image.png'} alt={entry.data.title} />
    </div>

    <div class="post-layout">
      <!-- Main Content -->
      <main class="post-content-wrapper">
        <header class="post-header">
          <div class="post-meta">
            <span class="category">{entry.data.category}</span>
            <span class="separator">•</span>
            <span class="date">Publicado el {formattedDate}</span>
          </div>
          <h1 class="post-title">{entry.data.title}</h1>
        </header>

        <!-- TOC Móvil -->
        {headings.length > 0 && (
          <nav class="toc-mobile">
            <h3 class="toc-title">En este artículo</h3>
            <ul class="toc-list">
              {headings.filter(h => h.depth <= 3).map(heading => (
                <li class={`toc-level-${heading.depth}`}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        )}

        <div class="post-content" data-pagefind-body>
          <Content />
        </div>
      </main>

      <!-- Sidebar -->
      <aside class="post-sidebar">
        <div class="sticky-container">
          
          <!-- TOC Desktop -->
          {headings.length > 0 && (
            <nav class="toc-desktop">
              <h3 class="toc-title">En este artículo</h3>
              <ul class="toc-list">
                {headings.filter(h => h.depth <= 3).map(heading => (
                  <li class={`toc-level-${heading.depth}`}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          )}

          <div class="sticky-card">
            <h3 class="agenda-title">Agendar Evaluación</h3>
          
          <div class="agenda-buttons">
            <a href="https://agendapro.com/site/cl/dermaval/388430" target="_blank" class="sidebar-btn sidebar-dark">
              <Calendar size={18} color="white" />
              Sede Valdivia
            </a>
            
            <a href="https://clinicabeeld.site.agendapro.com/cl/sucursal/138662/profesional/306232" target="_blank" class="sidebar-btn sidebar-dark">
              <Calendar size={18} color="white" />
              Sede Temuco
            </a>
          </div>

          <div class="sidebar-divider"></div>
          
          <span class="whatsapp-label">¿Tienes dudas?</span>
          <a href="#" class="sidebar-btn sidebar-whatsapp">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="white" aria-hidden="true"><path d={siWhatsapp.path} /></svg>
            Chat por WhatsApp
          </a>
        </div>
      </aside>
    </div>
  </article>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    // Dynamic TOC Highlighting
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          // Quitar clase activa a todos
          document.querySelectorAll('.toc-list a').forEach(link => {
            link.classList.remove('active');
          });
          // Añadir clase activa al correspondiente
          const activeLinks = document.querySelectorAll(`.toc-list a[href="#${id}"]`);
          activeLinks.forEach(link => link.classList.add('active'));
        }
      });
    }, { rootMargin: '-10% 0px -80% 0px' }); // Ajuste para activar cuando el título cruce el top

    // Observar todos los headings dentro del contenido
    document.querySelectorAll('.post-content h2, .post-content h3').forEach((heading) => {
      observer.observe(heading);
    });
  });
</script>

<style>
  .blog-header-spacing {
    height: 80px; /* Compensa el header fixed */
  }

  .post-container {
    max-width: 80%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .back-link-container {
    padding: 24px 0 16px 0;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--color-dark-gray);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .post-hero {
    width: 80%;
    margin: 0 auto;
    height: auto;
    background-color: transparent;
    border-radius: 16px;
    overflow: hidden;
  }

  .post-hero img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .post-layout {
    display: flex;
    flex-direction: column;
    padding: 32px 0;
    gap: 40px;
  }

  .post-content-wrapper {
    flex: 1;
    max-width: 100%;
  }

  .post-header {
    margin-bottom: 40px;
    border-bottom: 1px solid var(--color-light-gray);
    padding-bottom: 24px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: #666;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }

  .category {
    color: var(--color-primary-blue);
  }

  .post-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-black);
    line-height: 1.2;
    margin: 0;
  }

  /* Estilos para el markdown renderizado */
  .post-content {
    font-size: 1.05rem;
    line-height: 1.7;
    color: #333;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    color: var(--color-black);
    margin-top: 40px;
    margin-bottom: 16px;
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    color: var(--color-dark-gray);
    margin-top: 32px;
    margin-bottom: 16px;
  }

  .post-content :global(p) {
    margin-bottom: 24px;
  }

  .post-content :global(ul), .post-content :global(ol) {
    margin-bottom: 24px;
    padding-left: 24px;
  }

  .post-content :global(li) {
    margin-bottom: 8px;
  }

  /* Tabla de Contenidos (TOC) */
  .toc-title {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-black);
    margin-top: 0;
    margin-bottom: 16px;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .toc-list a {
    text-decoration: none;
    color: #888;
    font-size: 0.95rem;
    transition: color 0.2s, transform 0.2s;
    display: block;
    line-height: 1.4;
    border-left: 2px solid transparent;
    padding-left: 12px;
  }

  .toc-list a.active {
    color: var(--color-primary-blue);
    font-weight: 700;
    border-left: 2px solid var(--color-primary-blue);
    transform: translateX(4px);
  }

  .toc-level-3 {
    padding-left: 24px;
    font-size: 0.9rem;
  }

  .toc-mobile {
    background-color: var(--color-light-gray);
    padding: 24px;
    border-radius: 12px;
    margin-bottom: 32px;
  }

  .toc-desktop {
    display: none; /* Oculto en móvil */
  }

  /* Sidebar */
  .post-sidebar {
    width: 100%;
  }

  .sticky-container {
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: sticky;
    top: 100px;
  }

  .sticky-card {
    background-color: #fcfcfc;
    border: 1px solid var(--color-light-gray);
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    position: sticky;
    top: 100px; /* Para que no se pegue exactamente al borde de la pantalla */
  }

  .agenda-title {
    font-size: 1.125rem;
    font-weight: 800;
    text-align: center;
    color: var(--color-black);
    margin: 0 0 24px 0;
  }

  .agenda-buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sidebar-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    height: 48px;
    padding: 0 16px;
    box-sizing: border-box;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    color: white;
    transition: filter 0.2s, transform 0.2s;
  }

  .sidebar-btn:active {
    transform: scale(0.98);
  }

  .sidebar-dark {
    background-color: var(--color-dark-gray);
  }

  .sidebar-whatsapp {
    background-color: #25D366;
  }

  @media (hover: hover) {
    .sidebar-btn:hover {
      filter: brightness(1.2);
    }
    .sidebar-whatsapp:hover {
      filter: brightness(0.9);
    }
  }

  .sidebar-divider {
    height: 1px;
    background-color: var(--color-light-gray);
    margin: 24px 0;
  }

  .whatsapp-label {
    display: block;
    text-align: center;
    font-size: 0.875rem;
    color: #666;
    font-weight: 600;
    margin-bottom: 12px;
  }

  /* Responsive Desktop */
  @media (min-width: 769px) {
    @media (hover: hover) {
      .back-link:hover {
        color: var(--color-primary-blue);
      }
      .toc-list a:hover {
        color: var(--color-primary-blue);
        text-decoration: underline;
      }
    }

    .post-hero {
      height: auto;
    }

    .post-layout {
      flex-direction: row;
      justify-content: center;
      padding: 40px 0 64px 0;
      gap: 64px;
    }

    .post-content-wrapper {
      max-width: 700px; /* Ancho óptimo para lectura */
    }

    .post-title {
      font-size: 3rem;
    }

    .post-sidebar {
      width: 320px;
      flex-shrink: 0;
    }

    .toc-mobile {
      display: none;
    }

    .toc-desktop {
      display: block;
      background-color: var(--color-light-gray);
      padding: 24px;
      border-radius: 12px;
    }
  }
</style>
