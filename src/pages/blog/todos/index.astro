---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { ChevronLeft, ChevronRight } from 'lucide-astro';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('es-CL', {
    day: 'numeric',
    month: 'short',
    year: 'numeric'
  }).format(date);
};
---

<Layout title="Todas las publicaciones | NovaHair" description="Catálogo completo de artículos sobre salud capilar de NovaHair.">
  
  <main class="pagination-container">
    <div class="page-header">
      <div class="back-link-container">
        <a href="/blog" class="back-link">
          <ChevronLeft size={20} /> Volver al blog
        </a>
      </div>
      <h1 class="page-title">Todas las publicaciones</h1>
      
      <div class="pagination-controls-top">

        <div class="page-size-selector">
          <label for="page-size-select">Mostrar por página:</label>
          <select id="page-size-select" class="size-select">
            <option value="3">3</option>
            <option value="6" selected>6</option>
            <option value="12">12</option>
            <option value="24">24</option>
            <option value="48">48</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Contenedor donde se imprimirán todos los posts y JS los mostrará/ocultará -->
    <div class="recent-grid" id="posts-grid">
      {sortedPosts.map((post, index) => (
        <BlogCard post={post} class="pagination-item" data-index={index} />
      ))}
    </div>

    <nav class="pagination-controls-bottom" aria-label="Navegación de páginas">
      <button id="btn-prev" class="btn-page" aria-label="Página anterior">
        <ChevronLeft size={20} />
      </button>
      
      <div id="page-numbers" class="page-numbers-container">
        <!-- Generado dinámicamente -->
      </div>

      <button id="btn-next" class="btn-page" aria-label="Página siguiente">
        <ChevronRight size={20} />
      </button>
    </nav>
  </main>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const items = document.querySelectorAll('.pagination-item') as NodeListOf<HTMLElement>;
    const select = document.getElementById('page-size-select') as HTMLSelectElement;
    const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
    const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
    const pageNumbersContainer = document.getElementById('page-numbers');

    
    let currentPage = 1;
    let pageSize = parseInt(select.value, 10);
    const totalItems = items.length;

    function renderPage() {
      const totalPages = Math.ceil(totalItems / pageSize) || 1;
      
      // Ajustar la página si nos salimos del rango al cambiar de tamaño
      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;

      const startIndex = (currentPage - 1) * pageSize;
      const endIndex = startIndex + pageSize;

      // Mostrar/Ocultar items
      items.forEach((item, index) => {
        if (index >= startIndex && index < endIndex) {
          item.style.display = 'flex';
        } else {
          item.style.display = 'none';
        }
      });

      // Actualizar botones prev/next
      if (currentPage === 1) {
        btnPrev.classList.add('disabled');
        btnPrev.disabled = true;
      } else {
        btnPrev.classList.remove('disabled');
        btnPrev.disabled = false;
      }

      if (currentPage === totalPages) {
        btnNext.classList.add('disabled');
        btnNext.disabled = true;
      } else {
        btnNext.classList.remove('disabled');
        btnNext.disabled = false;
      }



      // Renderizar números
      if (pageNumbersContainer) {
        pageNumbersContainer.innerHTML = '';
        for (let i = 1; i <= totalPages; i++) {
          const btn = document.createElement('button');
          btn.className = `btn-page-num ${i === currentPage ? 'active' : ''}`;
          btn.textContent = i.toString();
          btn.addEventListener('click', () => {
            currentPage = i;
            renderPage();
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
          pageNumbersContainer.appendChild(btn);
        }
      }
    }

    // Inicializar
    renderPage();

    // Event Listeners
    select.addEventListener('change', (e) => {
      pageSize = parseInt((e.target as HTMLSelectElement).value, 10);
      currentPage = 1; // Volver al inicio al cambiar tamaño
      renderPage();
    });

    btnPrev.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        renderPage();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });

    btnNext.addEventListener('click', () => {
      const totalPages = Math.ceil(totalItems / pageSize);
      if (currentPage < totalPages) {
        currentPage++;
        renderPage();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  });
</script>

<style>
  .pagination-container {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 12px;
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 70px);
  }

  @media (min-width: 769px) {
    .pagination-container {
      max-width: 80%;
      padding: 0 20px;
    }
  }

  .page-header {
    text-align: center;
    padding: 60px 0 16px 0;
    margin-bottom: 32px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    z-index: 10;
    border-bottom: 1px solid var(--color-light-gray);
  }

  .back-link-container {
    display: flex;
    justify-content: flex-start;
    margin-bottom: 16px;
    padding: 0 16px;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--color-dark-gray);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-primary-blue);
  }

  .page-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary-blue);
    margin: 0 0 16px 0;
  }

  @media (min-width: 769px) {
    .page-title {
      font-size: 2.5rem;
    }
  }

  .pagination-controls-top {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 12px;
    padding: 0 16px;
  }



  .page-size-selector {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
    color: #555;
  }

  .size-select {
    padding: 6px 12px;
    border-radius: 8px;
    border: 1px solid var(--color-light-gray);
    background-color: var(--color-white);
    font-family: var(--font-body);
    font-size: 0.95rem;
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s;
  }

  .size-select:focus {
    border-color: var(--color-primary-blue);
  }

  /* Grid styles */
  .recent-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    flex-grow: 1;
    margin-bottom: 40px;
  }

  @media (min-width: 768px) {
    .recent-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .recent-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Control visibility of items handled by JS */
  :global(.pagination-item) {
    display: none; /* Ocultos por defecto hasta que JS cargue */
  }

  .pagination-controls-bottom {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    padding: 24px 0 40px 0;
    background: linear-gradient(to bottom, rgba(255,255,255,0) 0%, rgba(255,255,255,0.95) 20%, white 100%);
    z-index: 10;
  }

  .page-numbers-container {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    max-width: 200px;
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  
  .page-numbers-container::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 768px) {
    .page-numbers-container {
      max-width: 100%;
      overflow-x: visible;
    }
  }

  .btn-page {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background-color: var(--color-white);
    border: 1px solid var(--color-light-gray);
    color: var(--color-primary-blue);
    border-radius: 9999px;
    cursor: pointer;
    transition: all 0.2s;
    appearance: none;
    outline: none;
    padding: 0;
  }

  :global(.btn-page-num) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 48px;
    height: 48px;
    background-color: var(--color-white);
    border: 1px solid var(--color-light-gray);
    color: var(--color-dark-gray);
    border-radius: 9999px;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-body);
    appearance: none;
    outline: none;
    padding: 0 16px;
  }

  :global(.btn-page-num.active) {
    background-color: var(--color-primary-blue) !important;
    border-color: var(--color-primary-blue) !important;
    color: white !important;
  }

  @media (hover: hover) {
    .btn-page:not(.disabled):hover,
    :global(.btn-page-num:not(.active):hover) {
      background-color: var(--color-light-gray);
      color: var(--color-primary-blue);
      border-color: var(--color-primary-blue);
    }
  }

  .btn-page:active, :global(.btn-page-num:active) {
    transform: scale(0.95);
  }

  .btn-page.disabled {
    border-color: #e0e0e0;
    color: #ccc;
    cursor: not-allowed;
    background-color: #f9f9f9;
    opacity: 0.5;
  }
</style>
