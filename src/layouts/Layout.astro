---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="NovaHair - Medicina estética capilar" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-light.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/favicon-dark.png" media="(prefers-color-scheme: dark)" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
    
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    /* Variables Globales (AGENTS.md) */
    --color-black: #000000;
    --color-dark-gray: #1A1A1A;
    --color-white: #FFFFFF;
    --color-light-gray: #F5F5F5;
    --color-primary-blue: #5C6BC0;
    --color-accent-green: #25D366;
    --color-gold: #FFC107;

    /* Fuentes */
    --font-heading: 'Montserrat', sans-serif;
    --font-body: 'Open Sans', sans-serif;
  }

  /* Reset Básico y Mobile First */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    height: 100%;
    width: 100%;
  }

  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    font-family: var(--font-body);
    background-color: var(--color-white);
    color: var(--color-black);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    margin: 0;
    position: relative;
    /* Espacio para el BottomNav y botón flotante solo en móvil */
    padding-bottom: 150px;
  }

  @media (min-width: 769px) {
    body {
      padding-bottom: 0;
    }
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    color: var(--color-black);
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  button {
    font-family: var(--font-heading);
    cursor: pointer;
    border: none;
    outline: none;
    background: none;
  }

  /* Estilos base para imágenes y placeholders */
  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  /* Placeholder de imágenes para desarrollo */
  .img-placeholder {
    background-color: var(--color-light-gray);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-dark-gray);
    font-size: 0.875rem;
    border-radius: 8px;
  }
</style>
